POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=champ_local
FRONTEND_PORT=3001
BACKEND_PORT=8001

DEV_MODE=false
EDGE_ID=tatami-node-01
LOG_LEVEL=INFO

# BACKEND
EXTERNAL_API_URL=http://localhost:8000/api
EXTERNAL_API_TOKEN=service_token

# OUTBOX
PROCESSING_INTERVAL=1s
HTTP_TIMEOUT=10s
BATCH_SIZE=10

# FRONTEND
# Optional. Keep empty when using nginx + /api.
NEXT_PUBLIC_BACKEND_URL=
